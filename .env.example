# Stock symbol (Yahoo Finance ticker)
SYMBOL=DIS

# Date range for historical data
START_DATE=2018-01-01
END_DATE=2024-07-20

# LSTM hyperparameters
LOOKBACK=60
LSTM_UNITS=50
DROPOUT=0.2
EPOCHS=100
BATCH_SIZE=32
LEARNING_RATE=0.001

# Train/val/test split ratios (must sum to 1.0)
TRAIN_RATIO=0.70
VAL_RATIO=0.15
TEST_RATIO=0.15

# API
API_HOST=0.0.0.0
API_PORT=8000
